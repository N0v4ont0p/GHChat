{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GHchat",
  "version": "0.1.0",
  "identifier": "com.n0v4ont0p.ghchat",
  "build": {
    "beforeDevCommand": "pnpm dev --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm desktop:web:prepare",
    "frontendDist": "./desktop-shell"
  },
  "app": {
    "windows": [
      {
        "title": "GHchat",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": ["resources/web"]
  }
}
