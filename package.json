{
  "name": "ghchat",
  "version": "0.2.0",
  "description": "Premium macOS desktop AI chat app powered by Hugging Face",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:mac": "electron-vite build && CXXFLAGS='-std=gnu++20' electron-builder --mac --arm64 && CXXFLAGS='-std=gnu++20' electron-builder --mac --x64",
    "package:mac:arm64": "electron-vite build && CXXFLAGS='-std=gnu++20' electron-builder --mac --arm64",
    "lint": "eslint src electron --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rebuild:native": "CXXFLAGS='-std=gnu++20' electron-rebuild -f -w better-sqlite3",
    "package:mac:x64": "electron-vite build && CXXFLAGS='-std=gnu++20' electron-builder --mac --x64"
  },
  "dependencies": {
    "@huggingface/inference": "^2.8.1",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-query": "^5.99.2",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^11.18.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "sonner": "^1.4.41",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "electron": "^39.8.8",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.16",
    "typescript": "^5"
  }
}
